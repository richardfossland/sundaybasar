# ── App DATA project (shared SundayChess Supabase project, `basar` schema) ───
# anon key is public-by-design (inlined into the browser bundle). UNCHANGED by
# the host SSO work — anonymous join/play + the code-based host console use this.
NEXT_PUBLIC_SUPABASE_URL=https://fwbfhwxgkjelcutwajza.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-data-project-anon-key
NEXT_PUBLIC_APP_URL=https://basar.sundaysuite.app

# ── Service role for the host dashboard (SERVER ONLY — a Worker secret) ───────
# Used ONLY by the signed-in "Mine basarer" surface (owner-scoped list/delete +
# best-effort owner stamp). Set via: npx wrangler secret put SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=your-data-project-service-role-key

# ── Sunday Account (host SSO) — the ISSUER / identity Supabase project ────────
# A SEPARATE project from the DATA project above. These are SundayInfo's
# NEXT_PUBLIC_SUPABASE_URL / ANON_KEY (the SundayPlans / identity project) — the
# shared issuer that owns the `sb-*` session cookie on `.sundaysuite.app`.
NEXT_PUBLIC_SUNDAY_AUTH_URL=https://YOUR-ISSUER-PROJECT.supabase.co
NEXT_PUBLIC_SUNDAY_AUTH_ANON_KEY=issuer-anon-key

# Allow-list of arrangør emails that may act as a host (the ONE authz spot,
# fail-closed: empty = nobody). Comma / space / semicolon separated.
BASAR_ADMIN_EMAILS=arrangor@menigheten.no

# PRODUCTION ONLY: scope the Sunday Account session cookie to the parent domain
# so the login is shared across the suite (must stay UNSET on localhost).
NEXT_PUBLIC_COOKIE_DOMAIN=.sundaysuite.app
